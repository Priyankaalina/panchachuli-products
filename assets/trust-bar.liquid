<section class="trust-bar">
  <div class="page-width">
    <div class="trust-bar__grid">
      {% for block in section.blocks %}
        <div class="trust-bar__item">
          
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url }}"
              alt="{{ block.settings.heading }}"
              class="trust-bar__icon"
              loading="lazy"
            >
          {% endif %}

          <h3>{{ block.settings.heading }}</h3>

          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}

        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.trust-bar {
  padding: 30px 0;
  border-top: 1px solid #E8E0D0;
  border-bottom: 1px solid #E8E0D0;
  background: #fff;
}

.trust-bar__grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 30px;
}

.trust-bar__item {
  text-align: center;
}

.trust-bar__icon {
  width: 42px;
  height: 42px;
  object-fit: contain;
  margin-bottom: 12px;
}

.trust-bar__item h3 {
  margin: 0 0 6px;
  font-size: 18px;
  color: #213B2D;
  font-weight: 600;
}

.trust-bar__item p {
  margin: 0;
  font-size: 14px;
  color: #6A645C;
}

@media screen and (max-width: 990px) {
  .trust-bar__grid {
    grid-template-columns: repeat(2,1fr);
  }
}

@media screen and (max-width: 749px) {
  .trust-bar__grid {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "100% Pure"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Pure & natural products"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}