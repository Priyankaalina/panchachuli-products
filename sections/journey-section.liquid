<section
  class="journey-section"
  {% if section.settings.bg_image %}
    style="background-image:url('{{ section.settings.bg_image | image_url: width: 2000 }}');"
  {% endif %}
>
    <div class="journey-overlay"></div>
  <div class="page-width journey-content">

    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="journey-wrapper">

      {% for block in section.blocks %}

        <div class="journey-item">

          {% if block.settings.icon %}
            <img
              src="{{ block.settings.icon | image_url }}"
              alt="{{ block.settings.heading }}"
              class="journey-icon"
            >
          {% endif %}

          <h3>{{ block.settings.heading }}</h3>

          <p>{{ block.settings.text }}</p>

        </div>

        {% unless forloop.last %}
          <div class="journey-arrow">
            →
          </div>
        {% endunless %}

      {% endfor %}

    </div>

  </div>
</section>

<style>

.journey-section{
  padding:80px 0;
  background:#F8F4EA;
}

.section-header{
  text-align:center;
  margin-bottom:60px;
}

.section-header h2{
  font-size:48px;
  color:#213B2D;
  margin-bottom:12px;
}

.section-header p{
  color:#6A645C;
  max-width:700px;
  margin:auto;
}

.journey-wrapper{
  display:flex;
  align-items:flex-start;
  justify-content:center;
  gap:15px;
  flex-wrap:nowrap;
}

.journey-item{
  flex:1;
  text-align:center;
  max-width:220px;
}

.journey-icon{
  width:180px;
  height:180px;
  object-fit:contain;
  margin-bottom:18px;
}

.journey-item h3{
  font-size:18px;
  color:#213B2D;
  margin-bottom:10px;
}

.journey-item p{
  font-size:14px;
  line-height:1.6;
  color:#6A645C;
}

.journey-arrow{
  font-size:42px;
  color:#B68C42;
  margin-top:20px;
}

@media(max-width:990px){

  .journey-wrapper{
    flex-direction:column;
    align-items:center;
  }

  .journey-arrow{
    transform:rotate(90deg);
    margin:10px 0;
  }

}
@media screen and (max-width: 768px) {
  .journey-section {
    padding: 40px 0;
}
}

@media screen and (max-width: 590px) {
  .journey-section {
    padding: 10px 0;
}
.section-header h2 {
    font-size: 30px;
}
}

</style>

{% schema %}
{
  "name":"Journey Section",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"From Munsyari Village To Your Table"
    },
    {
      "type":"textarea",
      "id":"subheading",
      "label":"Subheading",
      "default":"Bringing authentic Himalayan goodness directly from the mountains to your home."
    },
    {
    "type": "image_picker",
    "id": "bg_image",
    "label": "Background Image"
    }
  ],
  "blocks":[
    {
      "type":"step",
      "name":"Journey Step",
      "settings":[
        {
          "type":"image_picker",
          "id":"icon",
          "label":"Icon"
        },
        {
          "type":"text",
          "id":"heading",
          "label":"Heading"
        },
        {
          "type":"textarea",
          "id":"text",
          "label":"Description"
        }
      ]
    }
  ],
  "max_blocks":5,
  "presets":[
    {
      "name":"Journey Section"
    }
  ]
}
{% endschema %}