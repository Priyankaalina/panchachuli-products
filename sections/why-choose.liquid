<section class="why-choose">
  <div class="page-width">
    <div class="why-choose__wrapper">

      <div class="why-choose__image">
        {% if section.settings.image %}
          {{ section.settings.image | image_url: width: 800 | image_tag }}
        {% endif %}
      </div>

      <div class="why-choose__content">
        <h2>{{ section.settings.heading }}</h2>

        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="benefit-item">

              {% if block.settings.icon %}
                <img
                  src="{{ block.settings.icon | image_url }}"
                  alt="{{ block.settings.title }}"
                  class="benefit-icon"
                >
              {% endif %}

              <div>
                <h4>{{ block.settings.title }}</h4>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="why-choose__badges">

        {% if section.settings.badge_1 %}
          <img src="{{ section.settings.badge_1 | image_url }}" alt="">
        {% endif %}

        {% if section.settings.badge_2 %}
          <img src="{{ section.settings.badge_2 | image_url }}" alt="">
        {% endif %}

        {% if section.settings.badge_3 %}
          <img src="{{ section.settings.badge_3 | image_url }}" alt="">
        {% endif %}

        {% if section.settings.badge_4 %}
          <img src="{{ section.settings.badge_4 | image_url }}" alt="">
        {% endif %}

      </div>

    </div>
  </div>
</section>

<style>
.why-choose{
  padding:80px 0;
  background:#fff;
}

.why-choose__wrapper{
  display:grid;
  grid-template-columns:1fr 1.2fr 180px;
  gap:50px;
  align-items:center;
}

.why-choose__image img{
  width:100%;
  height: 550px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
}
}

.why-choose__content h2{
  font-size:42px;
  color:#213B2D;
  margin-bottom:30px;
}

.benefit-item{
  display:flex;
  gap:16px;
  margin-bottom:24px;
}

.benefit-icon{
  width:40px;
  height:40px;
  object-fit:contain;
  flex-shrink:0;
}

.benefit-item h4{
  margin:0 0 6px;
  color:#213B2D;
  font-size:18px;
}

.benefit-item p{
  margin:0;
  color:#6A645C;
  line-height:1.6;
}

.why-choose__badges{
  display:flex;
  flex-direction:column;
  gap:16px;
}

.why-choose__badges img{
  width:120px;
  height:auto;
}

@media(max-width:990px){

  .why-choose__wrapper{
    grid-template-columns:1fr;
  }

  .why-choose__badges{
    flex-direction:row;
    flex-wrap:wrap;
    justify-content:center;
  }

}
@media screen and (max-width: 530px) {

.why-choose__badges img {
    width: 80px;
}
.why-choose__wrapper {
    gap: 20px;
  
}
}
</style>

{% schema %}
{
  "name":"Why Choose Panchachuli",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Why Choose Panchachuli Products?"
    },
    {
      "type":"image_picker",
      "id":"image",
      "label":"Left Image"
    },
    {
      "type":"image_picker",
      "id":"badge_1",
      "label":"Badge 1"
    },
    {
      "type":"image_picker",
      "id":"badge_2",
      "label":"Badge 2"
    },
    {
      "type":"image_picker",
      "id":"badge_3",
      "label":"Badge 3"
    },
    {
      "type":"image_picker",
      "id":"badge_4",
      "label":"Badge 4"
    }
  ],
  "blocks":[
    {
      "type":"benefit",
      "name":"Benefit",
      "settings":[
        {
          "type":"image_picker",
          "id":"icon",
          "label":"Icon"
        },
        {
          "type":"text",
          "id":"title",
          "label":"Title"
        },
        {
          "type":"textarea",
          "id":"text",
          "label":"Description"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"Why Choose Panchachuli"
    }
  ]
}
{% endschema %}